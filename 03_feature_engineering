    "# Drop only initial lag rows per reactor\n",
    "max_lag = 10\n",
    "\n",
    "df_model = (\n",
    "    df.groupby(\"reactor_id\", group_keys=False)\n",
    "      .apply(lambda x: x.iloc[max_lag:])\n",
    "      .reset_index(drop=True)\n",
    ")\n",
    "\n",
    "# Identify engineered columns that matter\n",
    "engineered_cols = [\n",
    "    col for col in df_model.columns\n",
    "    if (\n",
    "        \"_lag_\" in col\n",
    "        or \"_roll_\" in col\n",
    "        or \"_diff_\" in col\n",
    "        or \"_regime_dev\" in col\n",
    "        or \"_interaction\" in col\n",
    "        or \"_spike_flag\" in col\n",
    "        or \"fault_rolling_count\" in col\n",
    "    )\n",
    "]\n",
    "\n",
    "# Drop NaNs only in those engineered columns\n",
    "df_model = df_model.dropna(subset=engineered_cols).reset_index(drop=True)\n",
    "\n",
    "print(\"Final shape:\", df_model.shape)\n",
    "print(\"\\nClass distribution AFTER FIX:\")\n",
    "print(df_model[\"is_fault\"].value_counts())"
